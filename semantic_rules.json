  "parametric_mapping": {
    "constraint_solver": {
      "priority_rules": [
        "safety_critical > functional > aesthetic > optional",
        "manufacturing_constraints override user_preferences if conflict",
        "ergonomic_constraints override style_preferences if conflict"
      ],
      "solver_engine": "geometric_constraint_solver",
      "types": {
        "dimensional": [
          "distance",
          "angle",
          "radius",
          "diameter"
        ],
        "geometric": [
          "parallelism",
          "perpendicularity",
          "concentricity",
          "symmetry",
          "tangency"
        ],
        "manufacturing": [
          "draft_angle",
          "wall_thickness",
          "tool_access"
        ],
        "physical": [
          "center_of_gravity",
          "moment_of_inertia",
          "stress_limit"
        ]
      }
    },
    "object_templates": {
      "chair": {
        "class": "furniture",
        "ergonomic_reference": "ISO_7250",
        "parameters": {
          "armrests": {
            "height": {
              "default": 200,
              "rule": "seat_height - 250mm",
              "type": "dimension"
            },
            "length": {
              "default": 250,
              "type": "dimension"
            },
            "presence": {
              "default": false,
              "type": "boolean"
            }
          },
          "backrest": {
            "angle": {
              "default": 100,
              "range": [
                95,
                110
              ],
              "reference": "seat_angle",
              "type": "angle",
              "unit": "degrees"
            },
            "height": {
              "default": 400,
              "range": [
                200,
                600
              ],
              "type": "dimension"
            },
            "lumbar_support": {
              "default": true,
              "type": "boolean"
            },
            "width": {
              "default": 420,
              "rule": "seat_width - 20mm",
              "type": "dimension"
            }
          },
          "seat": {
            "angle": {
              "default": 5,
              "range": [
                0,
                15
              ],
              "type": "angle",
              "unit": "degrees"
            },
            "depth": {
              "default": 450,
              "range": [
                380,
                540
              ],
              "rule": "buttock_popliteal_length - 20-40mm",
              "type": "dimension"
            },
            "height": {
              "default": 450,
              "range": [
                400,
                500
              ],
              "rule": "popliteal_height + 20-40mm",
              "type": "dimension"
            },
            "width": {
              "default": 460,
              "range": [
                400,
                600
              ],
              "type": "dimension"
            }
          }
        }
      },
      "table": {
        "base_geometry": "parametric_solid",
        "class": "furniture",
        "parameters": {
          "apron": {
            "height": {
              "default": 100,
              "max": 200,
              "min": 50,
              "type": "dimension",
              "unit": "mm"
            },
            "reveal": {
              "default": 10,
              "max": 50,
              "min": 0,
              "type": "dimension",
              "unit": "mm"
            },
            "thickness": {
              "default": 30,
              "max": 60,
              "min": 20,
              "type": "dimension",
              "unit": "mm"
            }
          },
          "constraints": {
            "ergonomics": "height + top_thickness between 700 and 800 for dining",
            "manufacturing": "all_parts_thickness >= material_min_thickness",
            "stability": "leg_span >= 0.6 * top_diagonal"
          },
          "legs": {
            "attachment": {
              "default": "apron",
              "type": "enum",
              "values": [
                "apron",
                "direct",
                "pedestal",
                "trestle"
              ]
            },
            "count": {
              "default": 4,
              "max": 6,
              "min": 1,
              "parity": "prefer_even",
              "type": "integer"
            },
            "cross_section": {
              "default": "square",
              "type": "enum",
              "values": [
                "circular",
                "square",
                "rectangular",
                "tapered",
                "turned"
              ]
            },
            "diameter_width": {
              "default": 60,
              "max": 150,
              "min": 20,
              "type": "dimension",
              "unit": "mm"
            },
            "height": {
              "constraint": "function_of(top_thickness, target_table_height)",
              "default": 720,
              "max": 1200,
              "min": 100,
              "type": "dimension",
              "unit": "mm"
            },
            "taper": {
              "default": 0.1,
              "max": 0.5,
              "min": 0,
              "type": "ratio"
            }
          },
          "top": {
            "edge_profile": {
              "default": "chamfered",
              "type": "enum",
              "values": [
                "sharp",
                "chamfered",
                "rounded",
                "bullnose",
                "ogee"
              ]
            },
            "length": {
              "default": 1200,
              "max": 5000,
              "min": 200,
              "type": "dimension",
              "unit": "mm"
            },
            "overhang": {
              "default": 50,
              "max": 200,
              "min": 0,
              "type": "dimension",
              "unit": "mm"
            },
            "shape": {
              "default": "rectangular",
              "type": "enum",
              "values": [
                "rectangular",
                "circular",
                "oval",
                "square",
                "irregular"
              ]
            },
            "thickness": {
              "default": 40,
              "max": 200,
              "min": 10,
              "type": "dimension",
              "unit": "mm"
            },
            "width": {
              "constraint": "width <= length",
              "default": 800,
              "max": 3000,
              "min": 200,
              "type": "dimension",
              "unit": "mm"
            }
          }
        },
        "semantic_rules": {
          "Si \"basse\" ou \"coffee\" dans description → height = 450, shape préféré oval/rect": {},
          "Si \"carrée\" dans description → shape=square, length=width": {},
          "Si \"haute\" ou \"bar\" dans description → height += 300": {},
          "Si \"industriel\" → material=acier, cross_section=square, finish=brossé": {},
          "Si \"pieds tournés\" → cross_section=turned, style=traditional": {},
          "Si \"ronde\" dans description → shape=circular, length=width=diamètre": {}
        }
      }
    }
  },
