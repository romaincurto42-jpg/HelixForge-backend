    "feature_tree_structure": {
      "nodes": {
        "datum": {
          "types": [
            "plane",
            "axis",
            "point",
            "coordinate_system"
          ],
          "usage": "construction_reference"
        },
        "feature": {
          "dependencies": "parent_geometry",
          "types": [
            "boss",
            "cut",
            "fillet",
            "chamfer",
            "shell",
            "draft",
            "mirror",
            "pattern"
          ]
        },
        "sketch": {
          "constraints": [
            "fully_defined",
            "closed_loop"
          ],
          "operations": [
            "extrude",
            "revolve",
            "sweep",
            "loft"
          ],
          "type": "2D_profile"
        }
      },
      "root": "part_or_assembly"
    },
    "operation_sequence_rules": {
      "naming_conventions": {
        "extrusion": "Extrude_{direction}_{depth}",
        "fillet": "Fillet_{radius}_on_{edges}",
        "sketch": "{feature_name}_sketch"
      },
      "order_of_operations": [
        "base_feature_creation",
        "primary_datum_establishment",
        "secondary_features",
        "detail_features_fillets_chamfers",
        "shelling_if_required",
        "pattern_operations",
        "final_cleanup"
      ]
    }
  },
